# ── Bybit API ─────────────────────────────────────
BYBIT_API_KEY=your_key_here
BYBIT_API_SECRET=your_secret_here
USE_TESTNET=true               # Set to false for live trading

# ── Trading Settings ──────────────────────────────
SYMBOLS=BTC/USDT,XRP/USDT,MNT/USDT
TIMEFRAMES=15m,30m,1h
MIN_TIMEFRAME_CONFLUENCE=1
MARKET_TYPE=swap               # spot or swap
CANDLE_LIMIT=250
LOOP_INTERVAL=300             # seconds

# ── Risk Management ───────────────────────────────
MAX_RISK_PER_TRADE=0.01        # 1% of balance per trade
STOP_LOSS_PCT=0.02             # 2% stop loss
TAKE_PROFIT_PCT=0.04           # 4% take profit (2:1 R:R)

# ── Indicator Settings ───────────────────────────
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
EMA_FAST=20
EMA_SLOW=50
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BB_PERIOD=20
BB_STD=2.0
MIN_SIGNAL_CONFLUENCE=3

# ── Telegram Alerts ───────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_TOKEN=your_telegram_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Claude AI Sentiment (optional) ───────────────
SENTIMENT_ENABLED=false        # Set to true to enable
ANTHROPIC_API_KEY=your_anthropic_key_here
CRYPTOPANIC_KEY=your_cryptopanic_key_here

# ── Logging ───────────────────────────────────────
LOG_FILE=bot.log
LOG_LEVEL=INFO
